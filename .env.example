APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
DB_DATABASE=animal_hospital
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#ejemplo correo
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hola@animalhospital.test"
MAIL_FROM_NAME="${APP_NAME}"
#ruta para enviar correo de verificación
FRONTEND_URL=http://127.0.0.1:8000/api/v1/email/verify

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#JWT
JWT_SECRET=adfafafaffejemplo


#imágenes
# Intercambia entre: 'cloudinary', 'local', 'cloudflare' o 'google_drive'
IMAGE_DRIVER=cloudinary

# URL base de tu API (esencial para el almacenamiento local)
APP_URL=http://localhost:8000

# Credenciales de Cloudinary
CLOUDINARY_URL=CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@dmevednkc


# ID de la carpeta raíz en Drive que compartiste con la Cuenta de Servicio
GOOGLE_DRIVE_FOLDER_ID=1QXG8b9HcWjLxjK...

# Ruta absoluta al archivo de credenciales
GOOGLE_DRIVE_CREDENTIALS_PATH=storage/app/google-credentials.json


CLOUDFLARE_R2_ACCESS_KEY_ID=tu_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=tu_secret_access_key
CLOUDFLARE_R2_ENDPOINT=https://tu_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=mi-api-bucket
# URL pública de tu bucket (la activas en la pestaña "Settings" del bucket en Cloudflare)
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev
